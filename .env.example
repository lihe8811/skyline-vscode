# Copy this file to .env and replace every change-me value.
# Use URL-safe random values for account passwords.

MONGO_ROOT_USERNAME=skyline_admin
MONGO_ROOT_PASSWORD=change-me-root-password
MONGO_APP_DATABASE=oj_app
MONGO_APP_USERNAME=skyline_app
MONGO_APP_PASSWORD=change-me-app-password
MONGO_PORT=27017

BACKEND_PORT=3000
AUTH_TOKEN_SECRET=change-me-to-a-long-random-token-signing-secret
